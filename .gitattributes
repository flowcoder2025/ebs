# LF 강제 적용 (UTF-8 인코딩은 .editorconfig에서 관리)
* text=auto eol=lf

# 텍스트 파일
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.sh text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.py text eol=lf
*.rs text eol=lf
*.go text eol=lf
*.java text eol=lf
*.css text eol=lf
*.html text eol=lf

# 바이너리
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
