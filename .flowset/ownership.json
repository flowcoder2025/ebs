{
  "teams": {
    "director": {
      "owns": [
        "production/storyboard/**",
        "docs/**"
      ],
      "description": "스토리보드, 씬 구성, 비주얼 디렉션, 품질 관리"
    },
    "character": {
      "owns": [
        "production/characters/**",
        "production/prompts/characters/**"
      ],
      "description": "캐릭터 디자인 프롬프트, 스타일가이드, LoRA 관리"
    },
    "visual": {
      "owns": [
        "production/episodes/*/concept-art/**",
        "production/episodes/*/backgrounds/**",
        "production/prompts/scenes/**"
      ],
      "description": "미시세계 배경 프롬프트, ComfyUI 워크플로우, 비주얼 생성"
    },
    "animation": {
      "owns": [
        "production/episodes/*/animation/**",
        "production/episodes/*/composited/**",
        "production/prompts/workflows/**"
      ],
      "description": "모션 생성, 합성 가이드, 편집 타임라인"
    },
    "submission": {
      "owns": [
        "submission/**"
      ],
      "description": "공모 신청서, AI 기술 증빙, 포트폴리오"
    },
    "devops": {
      "owns": [
        ".github/**",
        ".claude/**",
        ".flowset/**"
      ],
      "description": "CI/CD, 프로젝트 설정, FlowSet"
    }
  },
  "shared": [
    "CLAUDE.md",
    ".gitignore",
    "production/assets/**"
  ],
  "crossTeamReview": [
    "production/storyboard/**",
    ".flowset/contracts/**"
  ]
}
